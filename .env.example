# Neon Postgres — pooled connection string (project "vedic-astro"). Copy from the Neon console.
DATABASE_URL=

# Prokerala Astrology API (production credentials from api.prokerala.com)
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

# OpenAI — powers AI readings, porondam explanations, dreams and palm. Optional:
# without it, readings fall back to a grounded template (dreams/palm need it).
OPENAI_API_KEY=
# Optional: default is gpt-4o-mini. Set gpt-4o for higher-fidelity Sinhala.
LLM_MODEL=

# Better Auth (Google sign-in). Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://codename-tharu.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Do NOT commit your real .env file.
